BUILI_API_HOST=0.0.0.0
BUILI_API_PORT=8000
BUILI_DATABASE_URL=sqlite:///./data/buili.db
BUILI_STORAGE_ROOT=./data/storage
BUILI_PUBLIC_BASE_URL=http://localhost:8000
BUILI_MODEL_GATEWAY_URL=http://localhost:8100
BUILI_REDIS_URL=redis://localhost:6379/0
BUILI_CORS_ORIGINS=http://localhost:3000
BUILI_MAX_UPLOAD_BYTES=262144000
BUILI_REQUIRE_AUTH_HEADERS=false
BUILI_AUTH_REQUIRED=false
BUILI_AUTH_SECRET=
BUILI_SECURE_COOKIES=false
BUILI_SESSION_HOURS=12
BUILI_REMEMBER_SESSION_DAYS=30
BUILI_PILOT_SEED_ENABLED=true
BUILI_PILOT_EMAIL=jordan.davis@northstarbuild.example
BUILI_PILOT_NAME=Jordan Davis
BUILI_PILOT_ORG_NAME=Northstar Builders
BUILI_PILOT_PROJECT_NAME=Cooper Residence — Electrical Rough-In Verification
# Set locally; never commit a real password. Render supplies this as a sync:false secret.
BUILI_PILOT_PASSWORD=
BUILI_SPATIAL_ENABLED=true
BUILI_SPATIAL_ALIGNMENT_MIN_CONFIDENCE=0.5

# Optional S3-compatible object storage. Leave blank for local development only.
BUILI_R2_ACCOUNT_ID=
BUILI_R2_ACCESS_KEY_ID=
BUILI_R2_SECRET_ACCESS_KEY=
BUILI_R2_BUCKET=

# The browser should normally use the same-origin Next.js /api proxy.
# Use an absolute API origin only when the frontend and API are intentionally split.
BUILI_INTERNAL_API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=/api
